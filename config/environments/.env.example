# PostgreSQL 配置
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=keycloak_db

# Keycloak 配置
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=changeme
KC_DB_PASSWORD=changeme
KC_HOSTNAME=keycloak.noda.co.nz
KC_HTTP_ENABLED=true

# Nginx 配置
NGINX_PORT=80
NGINX_SSL_PORT=443

# Cloudflare Tunnel 配置
CLOUDFLARE_TUNNEL_TOKEN=your-tunnel-token-here

# Jenkins 配置
JENKINS_ADMIN_ID=admin
JENKINS_API_TOKEN=your-api-token-here

# 应用配置
FINDCLASS_API_URL=http://localhost:3001
FINDCLASS_WEB_URL=https://class.noda.co.nz

# ============================================
# Noda 数据库备份系统配置（opdev）
# ============================================
# Backblaze B2 配置
B2_ACCOUNT_ID=your-b2-account-id-here
B2_APPLICATION_KEY=your-b2-application-key-here
B2_BUCKET_NAME=noda-backups
B2_PATH=backups/postgres/

# 备份告警配置
ALERT_EMAIL=your-alert-email@example.com
