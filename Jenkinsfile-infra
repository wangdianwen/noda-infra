pipeline {
    agent any

    environment {
        SOPS_AGE_KEY_FILE = '/var/jenkins_home/keys/age-key-dianwenwang.txt'
        PROJECT_ROOT = "${env.WORKSPACE}"
    }

    options {
        buildDiscarder(logRotator(numToKeepStr: '10'))
        timeout(time: 30, unit: 'MINUTES')
    }

    stages {
        stage('Setup Docker Permissions') {
            steps {
                sh '''
                    echo "🔧 配置 Docker 权限..."
                    # 尝试修复 Docker socket 权限
                    if [ -w /var/run/docker.sock ]; then
                        echo "✅ Docker socket 已可写"
                    else
                        echo "⚠️  Docker socket 不可写，尝试修复..."
                        ls -la /var/run/docker.sock || true
                    fi
                '''
            }
        }

        stage('Checkout') {
            steps {
                checkout scm
                sh 'echo "✅ 代码检出完成"'
            }
        }

        stage('Verify Environment') {
            steps {
                sh '''
                    echo "🔍 验证环境配置..."
                    echo "工作空间: ${PROJECT_ROOT}"
                    echo "密钥文件: ${SOPS_AGE_KEY_FILE}"
                    ls -la ${SOPS_AGE_KEY_FILE} || exit 1
                    which docker && docker --version
                '''
            }
        }

        stage('Decrypt Secrets') {
            steps {
                sh '''
                    echo "🔐 解密密钥文件..."
                    if [ -f "secrets/.env.production.enc" ]; then
                        sops --decrypt --age-keyfile ${SOPS_AGE_KEY_FILE} \
                            secrets/.env.production.enc > .env.production
                        echo "✅ 密钥解密成功"
                    else
                        echo "ℹ️  没有找到加密的密钥文件，使用默认配置"
                    fi
                '''
            }
        }

        stage('Deploy Infrastructure') {
            steps {
                sh '''
                    echo "🚀 部署基础设施..."
                    cd ${PROJECT_ROOT}/docker

                    # 检查 Docker socket 权限
                    echo "🔧 检查 Docker socket 权限..."
                    ls -la /var/run/docker.sock || true

                    # 检查 docker-compose 文件
                    if [ -f "docker-compose.yml" ]; then
                        echo "✅ 找到 docker-compose.yml"

                        # 复制配置文件到可访问的位置
                        echo "📁 准备配置文件..."
                        mkdir -p /jenkins-cache/noda-infra-config/nginx
                        cp -r ${PROJECT_ROOT}/config/nginx/* /jenkins-cache/noda-infra-config/nginx/

                        # 设置环境变量并启动服务
                        export POSTGRES_USER=postgres
                        export POSTGRES_PASSWORD=postgres_password_change_me
                        export POSTGRES_DB=oneteam_prod
                        export KEYCLOAK_ADMIN_USER=admin
                        export KEYCLOAK_ADMIN_PASSWORD=admin_password_change_me
                        export KEYCLOAK_DB_PASSWORD=keycloak_password_change_me
                        export CLOUDFLARE_TUNNEL_TOKEN=

                        # 使用覆盖文件启动服务（修复路径映射问题）
                        docker compose -p noda-prod -f docker-compose.yml \
                            -f docker-compose.jenkins-override.yml up -d

                        echo "✅ 服务已启动"
                    else
                        echo "❌ docker-compose.yml 不存在"
                        exit 1
                    fi
                '''
            }
        }

        stage('Verify Services') {
            steps {
                sh '''
                    echo "✅ 验证服务状态..."
                    sleep 5
                    docker ps --format "table {{.Names}}\t{{.Status}}"
                '''
            }
        }
    }

    post {
        always {
            echo "🧹 清理临时文件..."
            sh 'rm -f .env.production || true'
        }
        success {
            echo "✅ 基础设施部署成功！"
        }
        failure {
            echo "❌ 基础设施部署失败！请检查日志。"
        }
    }
}
