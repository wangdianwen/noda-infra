# ============================================
# noda-apps 环境变量文件
# ============================================
# 用途：manage-containers.sh 使用 envsubst 替换 ${VAR} 占位符后，
#       生成的临时文件传给 docker run --env-file
#
# 变量分类：
#   静态硬编码 - 不随环境变化
#   动态替换   - ${VAR} 语法，由宿主机环境变量填充
#     POSTGRES_USER, POSTGRES_PASSWORD, RESEND_API_KEY

NODE_ENV=production
NEXT_PUBLIC_LOCAL_API_URL=http://localhost:3001
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@noda-infra-postgres-prod:5432/noda_prod
DIRECT_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@noda-infra-postgres-prod:5432/noda_prod
KEYCLOAK_URL=https://auth.noda.co.nz
KEYCLOAK_INTERNAL_URL=http://noda-infra-nginx
KEYCLOAK_REALM=noda
KEYCLOAK_CLIENT_ID=noda-frontend
RESEND_API_KEY=${RESEND_API_KEY}
ANTHROPIC_AUTH_TOKEN=${ANTHROPIC_AUTH_TOKEN}
ANTHROPIC_BASE_URL=${ANTHROPIC_BASE_URL}
ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY}

# Email Service（运行时环境变量，非构建时）
KEYCLOAK_ADMIN_URL=http://noda-infra-nginx
KEYCLOAK_ADMIN_USER=${KEYCLOAK_ADMIN_USER}
KEYCLOAK_ADMIN_PASSWORD=${KEYCLOAK_ADMIN_PASSWORD}
TOKEN_SECRET=${TOKEN_SECRET}
EMAIL_SERVICE_API_KEY=${EMAIL_SERVICE_API_KEY}
AUTH_APP_URL=http://localhost:3004
RESEND_FROM_EMAIL=Noda <noreply@email.noda.co.nz>
