# Jenkins 管理员凭据配置
# 复制此文件为 jenkins-admin.env 并填写实际值
# jenkins-admin.env 不会被提交到 Git（已在 .gitignore 中排除）
#
# 用途：setup-jenkins.sh install 子命令将此文件复制到
#       /var/lib/jenkins/.admin.env（Jenkins init.groovy.d 脚本读取）
#
# 安全注意事项：
#   - jenkins-admin.env 文件权限应为 600（仅 jenkins 用户可读）
#   - 生产服务器上的文件系统保护由 setup-jenkins.sh 自动配置
#   - 切勿将实际密码提交到版本控制系统

JENKINS_ADMIN_USER=admin
JENKINS_ADMIN_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
