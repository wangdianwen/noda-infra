# ============================================
# Noda 数据库备份系统 - 环境变量配置
# ============================================
# 说明：复制此文件为 .env.backup 并填写实际值
# 警告：.env.backup 包含敏感信息，不要提交到 Git
# ============================================

# PostgreSQL 连接配置
POSTGRES_HOST=noda-infra-postgres-1
POSTGRES_PORT=5432
POSTGRES_USER=postgres
# 注意：密码将通过 .pgpass 文件管理，不在此配置中

# 备份目录配置（容器内路径）
BACKUP_DIR=/var/lib/postgresql/backup

# 宿主机备份目录映射路径（用于 volume 挂载）
BACKUP_HOST_DIR=/var/lib/docker/volumes/noda-infra_postgres_data/_data/backup

# 备份保留天数（默认 7 天）
RETENTION_DAYS=7

# 备份超时时间（秒，默认 1 小时）
TIMEOUT_SECONDS=3600

# 压缩级别（默认 -1 表示使用 pg_dump 默认值）
COMPRESSION_LEVEL=-1

# 并行备份（预留参数，Phase 1 固定为 false）
PARALLEL_BACKUP=false

# 云存储配置（预留，Phase 2 使用）
# ENABLE_CLOUD_UPLOAD=false
# B2_BUCKET_NAME=
# B2_APPLICATION_KEY_ID=
# B2_APPLICATION_KEY=

# 通知配置（预留，Phase 5 使用）
# WEBHOOK_URL=
# NOTIFICATION_ON_FAILURE=true
