FROM postgres:17-alpine

# 安装必需工具
RUN apk add --no-cache \
    rclone \
    coreutils \
    bash \
    jq \
    bc \
    openssl \
    postgresql-client

# 创建脚本目录
RUN mkdir -p /scripts/lib

# 复制脚本文件
COPY scripts/backup/lib/*.sh /scripts/lib/
COPY scripts/backup/test-verify-weekly.sh /scripts/

# 设置工作目录
WORKDIR /scripts

# 设置权限
RUN chmod +x /scripts/*.sh /scripts/lib/*.sh 2>/dev/null || true

# 验证安装
RUN rclone version && \
    psql --version && \
    pg_restore --version && \
    sha256sum --version

# 健康检查
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
  CMD pg_isready || exit 1

# 默认命令
CMD ["/bin/bash"]
